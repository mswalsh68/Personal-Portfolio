# Resend — contact form. Copy this file to .env.local and fill in.
# Get a key at https://resend.com (you already use Resend for LegacyLink).
RESEND_API_KEY=

# Address on a domain you've verified in Resend (e.g. contact@yourdomain.com).
# In dev you may use "onboarding@resend.dev".
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Where contact submissions are delivered (your inbox).
CONTACT_TO_EMAIL=
